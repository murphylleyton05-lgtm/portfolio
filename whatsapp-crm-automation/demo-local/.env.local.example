# Copiar a .env.local y completar. Version para demo local (localhost).

# ---- Chatwoot ----
# Generar una clave larga cualquiera (o pegar 128 caracteres al azar)
SECRET_KEY_BASE=pega_aca_una_clave_larga_de_al_menos_64_caracteres_cualquiera_1234567890

FRONTEND_URL=http://localhost:3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=demo1234

REDIS_URL=redis://:demo1234@redis:6379

RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker

# En local no hace falta mail real
ENABLE_ACCOUNT_SIGNUP=true

# ---- IA (Claude) ----
# Tu API key de Anthropic. El uso de la demo son centavos.
ANTHROPIC_API_KEY=sk-ant-REEMPLAZAR

# ---- Chatwoot API (para que n8n responda) ----
# Este token lo sacas DESPUES de crear el usuario admin en Chatwoot:
# Perfil -> Access Token. Lo pegas aca y reinicias n8n.
CHATWOOT_API_TOKEN=pega_el_token_despues
