{
  "name": "WhatsApp + Chatwoot + IA (Gemini GRATIS) - Respuesta y CRM",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "chatwoot-mensaje",
        "responseMode": "onReceived"
      },
      "name": "Webhook - Evento Chatwoot",
      "type": "n8n-nodes-base.webhook",
      "position": [220, 320]
    },
    {
      "parameters": {
        "conditions": {
          "string": [
            {
              "value1": "={{$json.body.event}}",
              "operation": "equal",
              "value2": "message_created"
            },
            {
              "value1": "={{$json.body.message_type}}",
              "operation": "equal",
              "value2": "incoming"
            }
          ]
        }
      },
      "name": "Filtro - Solo mensajes entrantes",
      "type": "n8n-nodes-base.if",
      "position": [440, 320]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key={{$env.GEMINI_API_KEY}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"system_instruction\": {\n    \"parts\": [{ \"text\": \"Sos el asistente de atencion al cliente de Xelvia Store, una tienda argentina de tecnologia importada (Apple, Samsung, smartwatches y gadgets). Respondes por chat de forma breve, amable y en espanol rioplatense. Ayudas con consultas de productos, precios, stock y envios. Si no sabes un dato puntual, decis que un asesor lo confirma enseguida. Responde SIEMPRE unicamente con un JSON valido con este formato exacto: {\\\"categoria\\\": \\\"Consulta_producto|Precio|Envio|Postventa|Otro\\\", \\\"respuesta\\\": \\\"tu respuesta lista para enviar\\\"}\" }]\n  },\n  \"contents\": [{\n    \"parts\": [{ \"text\": \"Mensaje del cliente: {{$json.body.content}}\" }]\n  }],\n  \"generationConfig\": { \"temperature\": 0.7, \"maxOutputTokens\": 800, \"responseMimeType\": \"application/json\" }\n}"
      },
      "name": "Gemini - Entender y responder",
      "type": "n8n-nodes-base.httpRequest",
      "position": [700, 260]
    },
    {
      "parameters": {
        "functionCode": "const src = $('Webhook - Evento Chatwoot').item.json.body;\ntry {\n  const raw = $input.item.json.candidates[0].content.parts[0].text;\n  const parsed = JSON.parse(raw);\n  return [{ json: {\n    respuesta: parsed.respuesta,\n    categoria: parsed.categoria,\n    account_id: src.account?.id || src.account_id,\n    conversation_id: src.conversation?.id || src.conversation_id\n  } }];\n} catch (e) {\n  return [{ json: {\n    respuesta: 'Gracias por tu mensaje! En un momento un asesor te responde.',\n    categoria: 'Otro',\n    account_id: src.account?.id || src.account_id,\n    conversation_id: src.conversation?.id || src.conversation_id,\n    error: e.message\n  } }];\n}"
      },
      "name": "Funcion - Parsear respuesta IA",
      "type": "n8n-nodes-base.code",
      "position": [940, 260]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CHATWOOT_URL}}/api/v1/accounts/{{$json.account_id}}/conversations/{{$json.conversation_id}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "api_access_token", "value": "={{$env.CHATWOOT_API_TOKEN}}"},
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "content", "value": "={{$json.respuesta}}"},
            {"name": "message_type", "value": "outgoing"}
          ]
        }
      },
      "name": "Chatwoot - Enviar respuesta",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1180, 260]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.CHATWOOT_URL}}/api/v1/accounts/{{$('Funcion - Parsear respuesta IA').item.json.account_id}}/conversations/{{$('Funcion - Parsear respuesta IA').item.json.conversation_id}}/labels",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {"name": "api_access_token", "value": "={{$env.CHATWOOT_API_TOKEN}}"},
            {"name": "content-type", "value": "application/json"}
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {"name": "labels", "value": "=[\"{{$('Funcion - Parsear respuesta IA').item.json.categoria}}\"]"}
          ]
        }
      },
      "name": "Chatwoot - Etiquetar en CRM",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1420, 260]
    }
  ],
  "connections": {
    "Webhook - Evento Chatwoot": {
      "main": [[ {"node": "Filtro - Solo mensajes entrantes", "type": "main", "index": 0} ]]
    },
    "Filtro - Solo mensajes entrantes": {
      "main": [
        [ {"node": "Gemini - Entender y responder", "type": "main", "index": 0} ],
        []
      ]
    },
    "Gemini - Entender y responder": {
      "main": [[ {"node": "Funcion - Parsear respuesta IA", "type": "main", "index": 0} ]]
    },
    "Funcion - Parsear respuesta IA": {
      "main": [[ {"node": "Chatwoot - Enviar respuesta", "type": "main", "index": 0} ]]
    },
    "Chatwoot - Enviar respuesta": {
      "main": [[ {"node": "Chatwoot - Etiquetar en CRM", "type": "main", "index": 0} ]]
    }
  },
  "settings": {
    "saveDataErrorExecution": "all",
    "saveDataSuccessExecution": "all",
    "saveManualExecutions": true
  }
}
