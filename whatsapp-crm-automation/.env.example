# ==========================================================
#  Copiar a .env y completar. NUNCA subir el .env real a git.
# ==========================================================

# ---- Chatwoot ----
# Generar con: openssl rand -hex 64
SECRET_KEY_BASE=REEMPLAZAR_POR_CLAVE_LARGA

# URL publica final (con https). Ej: https://chat.xelviastore.com
FRONTEND_URL=https://chat.tudominio.com

# Base de datos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DATABASE=chatwoot
POSTGRES_USERNAME=chatwoot
POSTGRES_PASSWORD=REEMPLAZAR_PASS_SEGURO

# Redis (misma pass que en docker-compose)
REDIS_PASSWORD=REEMPLAZAR_PASS_REDIS
REDIS_URL=redis://:REEMPLAZAR_PASS_REDIS@redis:6379

RAILS_ENV=production
NODE_ENV=production
INSTALLATION_ENV=docker

# Correo saliente (opcional pero recomendado para invitaciones/notificaciones)
MAILER_SENDER_EMAIL=Xelvia Store <soporte@tudominio.com>
SMTP_ADDRESS=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# Permite registro solo del admin (mas seguro)
ENABLE_ACCOUNT_SIGNUP=false

# ---- n8n ----
N8N_HOST=n8n.tudominio.com
N8N_USER=admin
N8N_PASSWORD=REEMPLAZAR_PASS_N8N
# Generar con: openssl rand -hex 24
N8N_ENCRYPTION_KEY=REEMPLAZAR_CLAVE_N8N

# ---- IA (Claude / Anthropic) ----
# Se carga como credencial dentro de n8n, no hace falta aca.
# ANTHROPIC_API_KEY=sk-ant-...

# ---- WhatsApp Cloud API (Meta) ----
# Estos valores van dentro de Chatwoot al crear el canal de WhatsApp.
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_BUSINESS_ACCOUNT_ID=
# WHATSAPP_ACCESS_TOKEN=
# WHATSAPP_VERIFY_TOKEN=
